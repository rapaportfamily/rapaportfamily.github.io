rules_version = '2';

// ╔══════════════════════════════════════════════════════════════════╗
// ║  Rapaport Family Tree — Firestore Security Rules                 ║
// ║                                                                  ║
// ║  Deployment model (D10 resolved 2026-05-17): SEPARATE Firebase   ║
// ║  project from RPA-PORT. Users sign in anonymously to Firebase;   ║
// ║  their real identity comes from the magic-link JWT validated     ║
// ║  client-side by assets/js/auth-gate.js. This means anyone who    ║
// ║  reached the SPA already presented a valid magic link.           ║
// ║                                                                  ║
// ║  Admin actions (approve/reject uploads) are CLIENT-ENFORCED      ║
// ║  for v1. Hardening with a Cloud Function that verifies the JWT   ║
// ║  server-side is a planned follow-up.                             ║
// ╚══════════════════════════════════════════════════════════════════╝

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    // ─── Uploads (pending review queue + approved items) ──────────
    match /family_uploads/{uploadId} {
      allow read: if isAuthed();
      allow create: if isAuthed()
                    && request.resource.data.status == 'pending'
                    && request.resource.data.uploader_sub is string
                    && request.resource.data.uploader_name is string
                    && request.resource.data.created_at == request.time;
      // Admin actions: update status + linked metadata, or delete
      allow update, delete: if isAuthed();
    }

    // ─── Future: chat / activity log / etc. — default deny ────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
